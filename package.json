{
  "name": "amalyatri",
  "version": "0.1.0",
  "private": true,
  "description": "Amal Yatri — the lifelong digital wellness companion for Amal Tamara Ayurveda guests",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm --workspace=@amalyatri/api run start:dev",
    "dev:web": "npm --workspace=@amalyatri/web run dev",
    "build": "npm-run-all build:packages build:api build:web",
    "build:packages": "npm --workspace=@amalyatri/shared run build && npm --workspace=@amalyatri/types run build && npm --workspace=@amalyatri/config run build",
    "build:api": "npm --workspace=@amalyatri/api run build",
    "build:web": "npm --workspace=@amalyatri/web run build",
    "lint": "npm-run-all --parallel lint:*",
    "lint:api": "npm --workspace=@amalyatri/api run lint",
    "lint:web": "npm --workspace=@amalyatri/web run lint",
    "test": "npm-run-all --parallel test:*",
    "test:api": "npm --workspace=@amalyatri/api run test",
    "test:web": "npm --workspace=@amalyatri/web run test",
    "db:generate": "npm --workspace=@amalyatri/prisma run generate",
    "db:migrate": "npm --workspace=@amalyatri/prisma run migrate:dev",
    "db:seed": "npm --workspace=@amalyatri/prisma run seed",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
