# Amal Yatri — root .env.example
# Copy this file to `.env` and edit. Never commit .env.

# Postgres
POSTGRES_USER=amalyatri
POSTGRES_PASSWORD=ama***change
# pgAdmin web UI: http://localhost:5050
PGADMIN_DEFAULT_EMAIL=admin@amalyatri.local
PGADMIN_DEFAULT_PASSWORD=***...ge

# API (used by apps/api inside Docker container)
NODE_ENV=development
PORT=3001
API_PREFIX=api

JWT_ACCESS_SECRET=dev_ac***change
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=dev_re...change
JWT_REFRESH_TTL=30d
BCRYPT_ROUNDS=10

AI_PROVIDER=stub
AI_API_KEY=

# Storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=./uploads

# CORS
CORS_ORIGINS=http://localhost:3000,http://web:3000
THROTTLE_TTL=60
THROTTLE_LIMIT=120
LOG_LEVEL=info

# Web (read by Next.js inside container)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
INTERNAL_API_URL=http://api:3001/api/v1
