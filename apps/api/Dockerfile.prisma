# ──────────────────────────────────────────────────────────────────────────────
# One-shot Prisma init image
# Build context must be monorepo root.  Used by:
#   docker compose --profile init up prisma-init
# Steps:
#   1. Run `prisma db push`  — apply schema to live Postgres
#   2. Run `tsx prisma/seed.ts` — load demo data
# ──────────────────────────────────────────────────────────────────────────────

FROM node:22-alpine
WORKDIR /repo

# Workspace resolution
COPY package.json package-lock.json ./
COPY packages/prisma/package.json ./packages/prisma/

# Install deps for the prisma workspace package
RUN npm ci --workspace=@amalyatri/prisma --include-workspace-root \
    && npm cache clean --force

# Copy the rest of the workspace
COPY packages/prisma/ ./packages/prisma/
COPY packages ./packages

# Generate Prisma client so the seed can `import { PrismaClient } from '@prisma/client'`
RUN cd packages/prisma && npx prisma generate

ENV DATABASE_URL=postgresql://amalyatri:***@postgres:5432/amalyatri?schema=public

WORKDIR /repo/packages/prisma

# Push schema, then run seed
CMD ["sh", "-c", "npx prisma db push --skip-generate && npx tsx prisma/seed.ts"]
