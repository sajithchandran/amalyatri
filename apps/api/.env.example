# ──────────────────────────────────────────────────────────────────────────────
# Amal Yatri API — environment variables
# Copy to .env  (and never commit .env)
# ──────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3001
API_PREFIX=api                          # routes resolve to /api/v1/*

# Database
DATABASE_URL=postgresql://amalyatri:amalyatri@localhost:5432/amalyatri?schema=public

# Auth — JWT
JWT_ACCESS_SECRET=please-change-me-to-a-32-byte-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=please-change-me-to-another-32-byte-random-string
JWT_REFRESH_TTL=30d
BCRYPT_ROUNDS=10

# AI (placeholder; swap real keys later)
AI_PROVIDER=stub                       # stub | openai | anthropic | local
AI_API_KEY=
AI_DEFAULT_MODEL=gpt-4o-mini

# Storage
STORAGE_PROVIDER=local                 # local | s3 | azure | minio
STORAGE_LOCAL_DIR=./uploads

# CORS
CORS_ORIGINS=http://localhost:3000

# Throttling
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# Logging
LOG_LEVEL=info
